# ============================================================
# Security headers para BAP Shop Admin (Cloudflare Pages)
# Estos headers protegen el HTML/JS del frontend contra XSS,
# clickjacking, y otras vulnerabilidades del lado del cliente.
# ============================================================

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 0
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https://api.bab-shop.com https://api-staging.bab-shop.com data: blob:; media-src 'self' https://api.bab-shop.com https://api-staging.bab-shop.com blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://api.bab-shop.com https://api-staging.bab-shop.com https://challenges.cloudflare.com https://static.cloudflareinsights.com; worker-src 'self' blob:; child-src 'self' blob: https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; manifest-src 'self'; upgrade-insecure-requests
