{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://bab-shop.com",
          "https://www.bab-shop.com",
          "https://admin.bab-shop.com"
        ],
        "methods": [
          "GET",
          "HEAD"
        ],
        "headers": [
          "*"
        ]
      },
      "exposeHeaders": [
        "ETag",
        "Content-Length",
        "Content-Type"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
